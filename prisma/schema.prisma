datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum HierarchyTier {
  LOCAL_CHURCH
  PARISH
  DIOCESE
  ARCHDIOCESE
  HEADQUARTERS
}

enum FundCategory {
  TITHE
  CESS
  OPERATIONS
  PROJECT
  WELFARE
  CALL_REGISTRY
  SADAKA
}

/// PLANNED -> ACTIVE -> COMPLETED is the normal path; STALLED covers a
/// paused/stuck project (the same category government project registers
/// track and audit separately from "ongoing"). Only ACTIVE projects accept
/// contributions via the public payment picker (see /api/projects) - a
/// PLANNED or STALLED project is visible in the admin panel but not yet
/// (or no longer, for now) open for giving.
enum ProjectStatus {
  PLANNED
  ACTIVE
  STALLED
  COMPLETED
  CANCELLED
}

enum WelfareCaseStatus {
  OPEN
  CLOSED
}

enum PermissionAccess {
  VIEW
  EDIT
}

enum PaymentIntentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum NotificationType {
  CONTRIBUTION_RECEIVED
  BALANCE_UPDATE
  PAYMENT_FAILED
  SYSTEM
}

/// Which door the money came through: the app's STK push (we already know
/// the payer before the money moves) vs. dialing the bare Paybill menu
/// directly (we only get a phone number and free-typed text, so payer
/// identification is best-effort - see UnmatchedPayment).
enum FundSourceChannel {
  APP_STK
  C2B_PAYBILL
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum GLTransactionType {
  CONTRIBUTION
  EXPENSE
  JOURNAL
  REVERSAL
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  SUPERSEDED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum Gender {
  MALE
  FEMALE
}

/// The nine standard church groups/fellowships every local church runs.
/// MEN and MOTHERS_COUNCIL are gender-scoped; MEDIUM/VICTORY/YOUTH/BRIGADE/
/// SUNDAY_SCHOOL are age-tiered (roughly oldest to youngest); CHOIR and
/// THE_ANOINTED are open to any age/gender and stack with whatever other
/// group a member already belongs to.
enum GroupCategory {
  MEN
  MOTHERS_COUNCIL
  MEDIUM
  VICTORY
  YOUTH
  BRIGADE
  SUNDAY_SCHOOL
  CHOIR
  THE_ANOINTED
}

enum GroupMembershipStatus {
  PROBATION
  ACTIVE
  SUSPENDED
}

model NationalHeadquarters {
  id             String        @id @default(uuid())
  title          String        @default("AIPCA Supreme Board - Bahati HQ")
  archbishopName String
  archdioceses   Archdiocese[]
}

model Archdiocese {
  id             String               @id @default(uuid())
  name           String
  headquartersId String
  headquarters   NationalHeadquarters @relation(fields: [headquartersId], references: [id])
  dioceses       Diocese[]

  @@unique([name, headquartersId])
}

model Diocese {
  id          String      @id @default(uuid())
  name        String
  bishopName  String
  archidId    String
  archdiocese Archdiocese @relation(fields: [archidId], references: [id])
  parishes    Parish[]

  @@unique([name, archidId])
}

model Parish {
  id                String        @id @default(uuid())
  name              String
  dioceseId         String
  diocese           Diocese       @relation(fields: [dioceseId], references: [id])
  tithePaybill      String        @default("700000")
  cessPaybill       String        @default("700001")
  operationsPaybill String        @default("700002")
  projectsPaybill   String        @default("700003")
  outposts          LocalChurch[]

  @@unique([name, dioceseId])
}

model LocalChurch {
  id                String             @id @default(uuid())
  name              String
  parishId          String
  parish            Parish             @relation(fields: [parishId], references: [id])
  members           Member[]
  attendanceRecords AttendanceRecord[]
  groups            Group[]
  dependents        Dependent[]
  /// The Cess quota for every member of this local church, due MONTHLY.
  /// Set once per congregation (quotas vary by location), not negotiated
  /// per member - see set-cess-target route. Null means unset - the
  /// dashboard must not invent a number or a "behind/on track" judgement.
  cessTargetAmount  Decimal?           @db.Decimal(12, 2)

  @@unique([name, parishId])
}

model Member {
  id                      String                  @id @default(uuid())
  membershipNo            String                  @unique
  idNumber                String?                 @unique
  name                    String
  phone                   String                  @unique
  dateOfBirth             DateTime?               @db.Date
  gender                  Gender?
  placeOfResidence        String?
  /// When the member actually joined the church - distinct from createdAt
  /// (when this DB row was created). For real registrations these are the
  /// same day; for bulk-seeded historical data they differ.
  joinedAt                DateTime?               @db.Date
  pinHash                 String?
  pinSetAt                DateTime?
  pinMustChange           Boolean                 @default(true)
  pinFailedAttempts       Int                     @default(0)
  pinLockedUntil          DateTime?
  localChurchId           String
  localChurch             LocalChurch             @relation(fields: [localChurchId], references: [id])
  contributions           Contribution[]          @relation("ContributionPayee")
  contributionsPaidFor    Contribution[]          @relation("ContributionPayer")
  positions               MemberPosition[]
  paymentIntents          PaymentIntent[]         @relation("PaymentIntentPayee")
  paymentIntentsInitiated PaymentIntent[]         @relation("PaymentIntentPayer")
  notifications           Notification[]
  attendanceRecords       AttendanceRecord[]
  groupMemberships        GroupMembership[]
  milestoneRecords        MemberMilestoneRecord[]
  dependents              Dependent[]
  glTransactionsPosted    GLTransaction[]         @relation("GLTransactionPoster")
  expensesSubmitted       Expense[]               @relation("ExpenseSubmitter")
  expensesApproved        Expense[]               @relation("ExpenseApprover")
  expensesPaid            Expense[]               @relation("ExpensePayer")
  createdAt               DateTime                @default(now())
}

/// One row per member per service. serviceType is a free label (e.g. "Sunday
/// Service", "Midweek Prayer") rather than an enum since this genuinely
/// varies by local church, not a fixed universal set like FundCategory.
/// groupId is set when this is a group meeting rather than a general
/// service - lets a GroupMembership's suspension status be computed from
/// real attendance history instead of a manually-maintained flag, once a
/// group attendance register UI exists (none does yet - see AttendanceTab).
model AttendanceRecord {
  id            String           @id @default(uuid())
  memberId      String
  member        Member           @relation(fields: [memberId], references: [id])
  localChurchId String
  localChurch   LocalChurch      @relation(fields: [localChurchId], references: [id])
  groupId       String?
  group         Group?           @relation(fields: [groupId], references: [id])
  serviceDate   DateTime         @db.Date
  serviceType   String
  status        AttendanceStatus
  recordedAt    DateTime         @default(now())

  @@unique([memberId, serviceDate, serviceType])
  @@index([localChurchId, serviceDate])
}

/// One instance of a standard group per local church (e.g. "Youth" at
/// Kenyatta Road Church is a different row from "Youth" at Juja Church).
/// Age bounds are inclusive and nullable for the gender-scoped and
/// age-independent categories - see GroupCategory.
model Group {
  id                String             @id @default(uuid())
  category          GroupCategory
  name              String
  localChurchId     String
  localChurch       LocalChurch        @relation(fields: [localChurchId], references: [id])
  minAge            Int?
  maxAge            Int?
  genderRestriction Gender?
  memberships       GroupMembership[]
  attendanceRecords AttendanceRecord[]

  @@unique([category, localChurchId])
}

/// A member's standing in one Group. New members start on a 3-month
/// probation (probationEndsAt = joinedGroupAt + 3 months); status flips to
/// ACTIVE once probation passes. SUSPENDED is meant to be driven by real
/// attendance (2+ months absent without notice, via AttendanceRecord with
/// this groupId) - there's no attendance-taking UI for groups yet, so for
/// now this is set directly rather than computed automatically.
/// Exactly one of memberId/dependentId is set - a child's group membership
/// (Sunday School, Brigade) belongs to their Dependent record, not a Member
/// row, since children don't have their own Member No./login/contributions.
model GroupMembership {
  id              String                @id @default(uuid())
  memberId        String?
  member          Member?               @relation(fields: [memberId], references: [id])
  dependentId     String?
  dependent       Dependent?            @relation(fields: [dependentId], references: [id])
  groupId         String
  group           Group                 @relation(fields: [groupId], references: [id])
  joinedGroupAt   DateTime              @db.Date
  probationEndsAt DateTime              @db.Date
  status          GroupMembershipStatus @default(PROBATION)
  endedAt         DateTime?             @db.Date

  @@unique([memberId, groupId])
  @@unique([dependentId, groupId])
}

/// A congregant too young to be a registered Member - no Member No., phone,
/// or login of their own, tracked instead as a dependent of an adult
/// guardian (real church practice - a Sunday School/Brigade register is
/// separate from the main membership roll). guardianId is nullable since
/// the actual parent/guardian relationship isn't always known.
model Dependent {
  id               String                  @id @default(uuid())
  name             String
  dateOfBirth      DateTime                @db.Date
  gender           Gender?
  guardianId       String?
  guardian         Member?                 @relation(fields: [guardianId], references: [id])
  localChurchId    String
  localChurch      LocalChurch             @relation(fields: [localChurchId], references: [id])
  groupMemberships GroupMembership[]
  milestoneRecords MemberMilestoneRecord[]
  createdAt        DateTime                @default(now())
}

/// Catalog of trackable spiritual milestones - mirrors the draft tiers
/// shown on the member dashboard (see app/dashboard/page.tsx HERITAGE/
/// MILESTONE_TIERS comments). "Holding a Leadership Position" is
/// deliberately NOT in this catalog - it's derived live from MemberPosition,
/// not a separate record, to avoid two sources of truth for the same fact.
model MilestoneType {
  id        String                  @id @default(uuid())
  key       String                  @unique
  tier      String
  title     String
  icon      String
  note      String
  sortOrder Int                     @default(0)
  records   MemberMilestoneRecord[]
}

/// Exactly one of memberId/dependentId is set - same convention as GroupMembership.
model MemberMilestoneRecord {
  id              String        @id @default(uuid())
  memberId        String?
  member          Member?       @relation(fields: [memberId], references: [id])
  dependentId     String?
  dependent       Dependent?    @relation(fields: [dependentId], references: [id])
  milestoneTypeId String
  milestoneType   MilestoneType @relation(fields: [milestoneTypeId], references: [id])
  achievedAt      DateTime      @db.Date

  @@unique([memberId, milestoneTypeId])
  @@unique([dependentId, milestoneTypeId])
}

/// memberId is the account credited (the payee); paidByMemberId is whoever
/// actually submitted the payment when it's not the same person - e.g. a
/// daughter settling her mother's cess from her own phone. Both are kept for
/// the permanent ledger's audit trail, not just the ephemeral PaymentIntent.
model Contribution {
  id               String            @id @default(uuid())
  memberId         String
  member           Member            @relation("ContributionPayee", fields: [memberId], references: [id])
  paidByMemberId   String?
  paidByMember     Member?           @relation("ContributionPayer", fields: [paidByMemberId], references: [id])
  amount           Decimal           @db.Decimal(10, 2)
  category         FundCategory
  projectId        String?
  project          Project?          @relation(fields: [projectId], references: [id])
  welfareCaseId    String?
  welfareCase      WelfareCase?      @relation(fields: [welfareCaseId], references: [id])
  mpesaReceiptNo   String            @unique
  dateTransacted   DateTime          @default(now())
  sourceChannel    FundSourceChannel @default(APP_STK)
  paybillNumber    String?
  paymentIntent    PaymentIntent?
  notifications    Notification[]
  unmatchedPayment UnmatchedPayment?
  glTransactions   GLTransaction[]

  @@index([memberId])
  @@index([category])
}

/// Chart of Accounts - fixed reference data (see prisma/seed.ts), not demo
/// data. code is the stable identifier, never renamed; a retired account
/// gets isActive:false rather than deleted. fundCategory ties an INCOME
/// account 1:1 to the existing FundCategory enum so contribution
/// auto-posting can resolve "which account credits this" via a lookup, not
/// a hardcoded switch - null for every non-income account.
model Account {
  id            String          @id @default(uuid())
  code          String          @unique
  name          String
  type          AccountType
  fundCategory  FundCategory?   @unique
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  debitEntries  GLTransaction[] @relation("DebitAccount")
  creditEntries GLTransaction[] @relation("CreditAccount")
  expenses      Expense[]
}

/// One immutable double-entry row - exactly one debit account, one credit
/// account, one amount (never separate debit/credit amount columns).
/// scopeTier/scopeId is denormalized at posting time so reports can
/// tree-walk the hierarchy without joining back through
/// Contribution/Expense every time. Corrections post a new REVERSAL row
/// (debit/credit swapped, description prefixed "REVERSAL:") rather than
/// editing or deleting an existing row - see lib/accounting/postEntry.ts.
model GLTransaction {
  id               String            @id @default(uuid())
  date             DateTime          @default(now())
  description      String
  debitAccountId   String
  debitAccount     Account           @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccountId  String
  creditAccount    Account           @relation("CreditAccount", fields: [creditAccountId], references: [id])
  amount           Decimal           @db.Decimal(12, 2)
  txnType          GLTransactionType
  scopeTier        HierarchyTier
  scopeId          String
  contributionId   String?
  contribution     Contribution?     @relation(fields: [contributionId], references: [id])
  expenseId        String?
  expense          Expense?          @relation(fields: [expenseId], references: [id])
  /// Set on the NEW row a reversal creates, pointing back at the original.
  /// @unique caps each original entry at exactly one reversal.
  reversalOfId     String?           @unique
  reversalOf       GLTransaction?    @relation("Reversal", fields: [reversalOfId], references: [id])
  reversedBy       GLTransaction?    @relation("Reversal")
  postedByMemberId String?
  postedByMember   Member?           @relation("GLTransactionPoster", fields: [postedByMemberId], references: [id])
  createdAt        DateTime          @default(now())

  @@index([scopeTier, scopeId])
  @@index([debitAccountId])
  @@index([creditAccountId])
  @@index([contributionId])
  @@index([expenseId])
  @@index([date])
}

/// A disbursement, raised at any tier via the same scopeTier/scopeId
/// pattern as Project/WelfareCase (a local church's diesel bill vs. a
/// diocese's office rent vs. HQ's campaign cost). Workflow: PENDING
/// (submitted) -> APPROVED -> PAID (posts Dr expense account / Cr cash via
/// lib/accounting/postEntry.ts), or REJECTED any time before PAID. The
/// submitter only ever picks expenseAccountId (an EXPENSE-type Account -
/// a category label like "Utilities") and an amount/description - the
/// offsetting cash account is resolved automatically at pay time, never
/// chosen by a user. Double-entry mechanics stay invisible here.
model Expense {
  id                  String          @id @default(uuid())
  scopeTier           HierarchyTier
  scopeId             String
  description         String
  amount              Decimal         @db.Decimal(12, 2)
  expenseAccountId    String
  expenseAccount      Account         @relation(fields: [expenseAccountId], references: [id])
  vendorName          String?
  status              ExpenseStatus   @default(PENDING)
  submittedByMemberId String
  submittedByMember   Member          @relation("ExpenseSubmitter", fields: [submittedByMemberId], references: [id])
  approvedByMemberId  String?
  approvedByMember    Member?         @relation("ExpenseApprover", fields: [approvedByMemberId], references: [id])
  approvedAt          DateTime?
  rejectionReason     String?
  paidAt              DateTime?
  paidByMemberId      String?
  paidByMember        Member?         @relation("ExpensePayer", fields: [paidByMemberId], references: [id])
  glTransactions      GLTransaction[]
  createdAt           DateTime        @default(now())

  @@index([scopeTier, scopeId])
  @@index([status])
}

/// Scoped to any tier of the AIPCA hierarchy (a local church's roofing fund,
/// a parish building project, a diocesan initiative, or a national HQ
/// campaign) via the same scopeTier/scopeId pattern as MemberPosition -
/// this app is the national AIPCA backbone, not a single-parish tool.
model Project {
  id             String             @id @default(uuid())
  scopeTier      HierarchyTier
  scopeId        String
  name           String
  description    String?
  location       String?
  leadContact    String?
  targetAmount   Decimal            @db.Decimal(12, 2)
  status         ProjectStatus      @default(ACTIVE)
  startDate      DateTime           @default(now())
  endDate        DateTime?
  milestones     ProjectMilestone[]
  contributions  Contribution[]
  paymentIntents PaymentIntent[]
  createdAt      DateTime           @default(now())

  @@index([scopeTier, scopeId])
}

/// A phase of a Project's implementation plan (Foundation, Walls, Roofing...)
/// - the "concrete structure" a government project register shows: dated,
/// budgeted stages marked complete one at a time, not a single lump status.
/// completed is toggled directly by a leader, never inferred from money
/// raised - Contribution has no per-milestone link.
model ProjectMilestone {
  id           String    @id @default(uuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id])
  title        String
  description  String?
  targetAmount Decimal?  @db.Decimal(12, 2)
  dueDate      DateTime?
  completed    Boolean   @default(false)
  completedAt  DateTime?
  order        Int       @default(0)

  @@index([projectId])
}

/// Same scopeTier/scopeId pattern as Project - a welfare case can be raised
/// at local-church level (a member's bereavement) or scaled up to
/// diocese/national level (a disaster relief fund), without a schema change.
model WelfareCase {
  id              String            @id @default(uuid())
  scopeTier       HierarchyTier
  scopeId         String
  title           String
  description     String?
  beneficiaryName String?
  targetAmount    Decimal?          @db.Decimal(12, 2)
  status          WelfareCaseStatus @default(OPEN)
  contributions   Contribution[]
  paymentIntents  PaymentIntent[]
  createdAt       DateTime          @default(now())
  closedAt        DateTime?

  @@index([scopeTier, scopeId])
}

/// A church position/office (e.g. Chairman, Group Leader, Treasurer) that can
/// be granted a set of admin-panel permissions and assigned to members.
model Role {
  id            String           @id @default(uuid())
  name          String           @unique
  scope         HierarchyTier
  description   String?
  permissions   RolePermission[]
  positions     MemberPosition[]
  notifications Notification[]
}

/// A single grantable capability, e.g. "admin.attendance.manage".
/// Absence of a RolePermission row for a given Role+Permission is the
/// default "frozen" (no access) state - there is no explicit NONE value.
model Permission {
  id      String           @id @default(uuid())
  key     String           @unique
  label   String
  section String
  roles   RolePermission[]
}

model RolePermission {
  id           String           @id @default(uuid())
  roleId       String
  role         Role             @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission       @relation(fields: [permissionId], references: [id])
  access       PermissionAccess

  @@unique([roleId, permissionId])
}

/// Assigns a Member to a Role within a specific hierarchy scope (the id of
/// the LocalChurch/Parish/Diocese/etc matching Role.scope). Polymorphic by
/// design - not FK-constrained to a single table - since scope depends on
/// the tier the Role applies to. endDate = null means the position is current.
model MemberPosition {
  id        String    @id @default(uuid())
  memberId  String
  member    Member    @relation(fields: [memberId], references: [id])
  roleId    String
  role      Role      @relation(fields: [roleId], references: [id])
  scopeId   String
  startDate DateTime  @default(now())
  endDate   DateTime?

  @@index([memberId])
  @@index([scopeId])
}

/// Staged before every M-Pesa STK push, since Daraja's callback only echoes
/// back CheckoutRequestID/Amount - this row is how the callback learns what
/// the payment was actually for (category/project/welfare case). memberId is
/// the payee (account credited, resolved from the Church No./ID No. the
/// payer typed in - not necessarily the signed-in operator); phoneNumber is
/// whichever phone receives the STK push and may belong to someone else
/// entirely (e.g. a daughter paying on her mother's behalf).
model PaymentIntent {
  id                String              @id @default(uuid())
  checkoutRequestId String              @unique
  merchantRequestId String?
  memberId          String
  member            Member              @relation("PaymentIntentPayee", fields: [memberId], references: [id])
  paidByMemberId    String?
  paidByMember      Member?             @relation("PaymentIntentPayer", fields: [paidByMemberId], references: [id])
  amount            Decimal             @db.Decimal(10, 2)
  category          FundCategory
  projectId         String?
  project           Project?            @relation(fields: [projectId], references: [id])
  welfareCaseId     String?
  welfareCase       WelfareCase?        @relation(fields: [welfareCaseId], references: [id])
  phoneNumber       String
  status            PaymentIntentStatus @default(PENDING)
  failureReason     String?
  contributionId    String?             @unique
  contribution      Contribution?       @relation(fields: [contributionId], references: [id])
  createdAt         DateTime            @default(now())
  resolvedAt        DateTime?

  @@index([memberId])
}

/// A direct Paybill-menu payment (not via the app) that we couldn't safely
/// turn into a Contribution automatically - either the payer's phone didn't
/// match a registered Member, or the free-typed Account No. didn't parse to
/// a fund we're confident about. Sadaka/general offering can be resolved
/// with no member match at all (resolvedContributionId stays null); Tithe/
/// Cess/Call Registry must be matched to a real member before they count,
/// since those feed a personal running balance (and Call Registry doubles
/// as attendance proof) - see lib/payments.ts.
model UnmatchedPayment {
  id                     String        @id @default(uuid())
  mpesaReceiptNo         String        @unique
  amount                 Decimal       @db.Decimal(10, 2)
  payerPhone             String
  rawAccountText         String
  guessedCategory        FundCategory?
  paybillNumber          String
  transactionDate        DateTime
  resolvedAt             DateTime?
  resolvedContributionId String?       @unique
  resolvedContribution   Contribution? @relation(fields: [resolvedContributionId], references: [id])
  resolutionNote         String?
  createdAt              DateTime      @default(now())

  @@index([resolvedAt])
}

model Notification {
  id                    String           @id @default(uuid())
  type                  NotificationType
  title                 String
  body                  String
  memberId              String?
  member                Member?          @relation(fields: [memberId], references: [id])
  targetRoleId          String?
  targetRole            Role?            @relation(fields: [targetRoleId], references: [id])
  relatedContributionId String?
  relatedContribution   Contribution?    @relation(fields: [relatedContributionId], references: [id])
  read                  Boolean          @default(false)
  createdAt             DateTime         @default(now())

  @@index([memberId])
  @@index([targetRoleId])
}

/// Written directly by the Python crawler (crawler/), not through Prisma
/// Client - hence @@map/@map to snake_case, and a DB-level default on `id`
/// so a raw INSERT still gets a UUID. `url` is NOT a hard unique constraint:
/// a changed hash on an already-APPROVED row inserts a *new* row (previous
/// row kept byte-for-byte, marked SUPERSEDED) so a CuratedContent citation
/// into the old row never has its content silently rewritten underneath it.
/// That means two rows can legitimately share a url (current + superseded
/// history) - the crawler (single writer, low frequency) is responsible for
/// only ever having one non-SUPERSEDED row per url at a time.
model KnowledgeSource {
  id                String           @id @default(dbgenerated("gen_random_uuid()::text")) @map("id")
  url               String
  title             String?
  rawMarkdown       String           @map("raw_markdown")
  contentHash       String           @map("content_hash")
  reviewStatus      ReviewStatus     @default(PENDING) @map("review_status")
  previousVersionId String?          @unique @map("previous_version_id")
  previousVersion   KnowledgeSource? @relation("KnowledgeSourceVersion", fields: [previousVersionId], references: [id])
  nextVersion       KnowledgeSource? @relation("KnowledgeSourceVersion")
  crawledAt         DateTime         @default(now()) @map("crawled_at")
  lastCheckedAt     DateTime         @default(now()) @map("last_checked_at")

  @@index([url])
  @@index([reviewStatus])
  @@map("knowledge_sources")
}

/// One row per crawler invocation, for basic observability once this runs
/// unattended (Phase 5b, GitHub Actions).
model CrawlRun {
  id         String    @id @default(dbgenerated("gen_random_uuid()::text")) @map("id")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  attempted  Int       @default(0)
  succeeded  Int       @default(0)
  changed    Int       @default(0)
  failed     Int       @default(0)

  @@map("crawl_runs")
}
